# ──────────────────────────────────────────────────────
# Gmail SMTP Configuration
# ──────────────────────────────────────────────────────
# How to get App Password:
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" as app, "Other" as device, name it
# 4. Copy the 16-character App Password (remove spaces)

# SMTP Server (default Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Email yang LOGIN ke Gmail SMTP (akun yang punya App Password)
SMTP_USER=your-email@gmail.com

# App Password dari Google (16 karakter, tanpa spasi)
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Alamat "From" yang tampil di email (Gmail akan paksa sama dengan SMTP_USER)
SMTP_FROM=your-email@gmail.com

# Email tujuan (inbox masuk untuk pesan form contact)
SMTP_TO=your-email@gmail.com
