generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id           Int      @id @default(autoincrement())
  filename     String
  originalName String
  path         String
  description  String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Event {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  title       String
  description String
  content     String?   @db.LongText
  image       String?
  location    String?
  startDate   DateTime
  endDate     DateTime
  category    String?
  status      String    @default("upcoming")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
